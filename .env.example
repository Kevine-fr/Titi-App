# Postgres
POSTGRES_USER=fileapp
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=fileapp

# Session : DOIT faire au moins 32 caractères
# Génère-le avec : openssl rand -base64 32
SESSION_PASSWORD=changeme_use_openssl_rand_base64_32_minimum_chars

# Premier compte admin (créé automatiquement au démarrage)
[email protected]
ADMIN_PASSWORD=changeme_strong_admin_password

# Taille max upload en Mo (par défaut 1024 = 1 Go)
MAX_UPLOAD_SIZE_MB=1024

# Port HTTP exposé sur la machine hôte
HTTP_PORT=80
